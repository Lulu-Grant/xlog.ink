# Copy this file to your deployment environment and replace placeholder values.

TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Optional: comma-separated trusted reverse proxy IPs
